# PostgreSQL connection.
# Copy this file to `.env` and adjust as needed:  cp .env.example .env
#
# Both docker-compose.yml and src/main/resources/application-postgres.yaml
# read these variables. Keeping them in one .env file means the database
# container and the Spring Boot app always agree on the same credentials.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tb001
POSTGRES_USER=tb001
POSTGRES_PASSWORD=tb001
